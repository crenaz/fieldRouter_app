<!DOCTYPE html>
<html>
<head>
  <title>FieldRouter</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <!-- Modern Rails 8 frontend tags -->
  <%= stylesheet_link_tag "application", media: "all" %>
  <%= javascript_include_tag "application", type: "module" %>

  <!-- Bootstrap CSS -->
  <link href="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.7/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>

<nav class="navbar navbar-default">
  <div class="container">
    <div class="navbar-header">
      <button type="button" class="navbar-toggle collapsed" data-toggle="collapse" data-target="#navbar" aria-expanded="false">
        <span class="sr-only">Toggle navigation</span>
        <span class="icon-bar"></span>
        <span class="icon-bar"></span>
        <span class="icon-bar"></span>
      </button>
      <%= link_to "FieldRouter", root_path, class: "navbar-brand" %>
    </div>
    
    <div class="collapse navbar-collapse" id="navbar">
      <ul class="nav navbar-nav">
        <li class="active"><%= link_to "Home", root_path %></li>
        <li><a href="#">Routes</a></li>
        <li><a href="#">History</a></li>
      </ul>
    </div>
  </div>
</nav>

<div class="container">
  <%= yield %>
</div>

<!-- e.g., app/views/home/index.html.erb -->
<div id="map" style="height: 300px; width: 100%;"></div>

<footer class="footer" style="margin-top: 50px; padding: 20px 0; border-top: 1px solid #eee;">
  <div class="container">
    <p class="text-muted">&copy; <%= Time.current.year %> FieldRouter</p>
  </div>
</footer>

<!-- Bootstrap JavaScript -->
<script src="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.7/js/bootstrap.min.js"></script>

</body>
</html>
