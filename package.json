{
  "name": "fieldrouter_app",
  "private": true,
  "dependencies": {
    "@hotwired/stimulus": "^3.3.1",
    "@hotwired/turbo-rails": "^2.0.23",
    "esbuild": "^0.28.0",
    "tailwindcss": "^3.3.3"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.15",
    "postcss": "^8.4.31"
  },
  "scripts": {
    "build": "esbuild app/javascript/*.* --bundle --sourcemap --format=esm --outdir=app/assets/builds --public-path=/assets",
    "build:css": "tailwindcss -i ./app/assets/stylesheets/application.tailwind.css -o ./app/assets/builds/application.css --minify",
    "build:all": "npm run build && npm run build:css",
    "watch": "esbuild app/javascript/*.* --bundle --sourcemap --format=esm --outdir=app/assets/builds --public-path=/assets --watch",
    "watch:css": "tailwindcss -i ./app/assets/stylesheets/application.tailwind.css -o ./app/assets/builds/application.css --watch",
    "dev": "concurrently \"npm run watch\" \"npm run watch:css\""
  }
}